# Node configuration
NODE_ENV=production
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumanet
DB_USER=lumanet_user
DB_PASSWORD=your_secure_password

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here
ADMIN_PASSWORD=admin123

# Node identification
NODE_ID=lumanet-node-1
NODE_NAME=Main Campus Server

# XBee serial configuration
XBEE_PORT=/dev/ttyUSB0
XBEE_BAUD=115200

# File storage
UPLOAD_DIR=/home/pi/lumanet/server/src/storage/uploads
MAX_FILE_SIZE=52428800
